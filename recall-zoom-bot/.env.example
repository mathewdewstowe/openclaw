# Server
PORT=3000

# Virtual display (Xvfb)
DISPLAY=:99

# PulseAudio (virtual devices are created by setup.sh)
PULSE_SERVER=unix:/tmp/pulseaudio.socket

# Chromium path (required — install via: apt install chromium-browser)
CHROME_PATH=/usr/bin/chromium-browser

# Avatar page (served locally by this server)
AVATAR_URL=http://localhost:3000/agent.html
