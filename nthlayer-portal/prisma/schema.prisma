generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── V2 Models ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  company      String?  // legacy — use Company model for v2
  jobTitle     String?
  passwordHash String
  role         String   @default("USER") // legacy: USER | ADMIN
  systemRole   String   @default("member") // super_admin | admin | operator | member | viewer
  isActive     Boolean  @default(true)
  planId       String?
  plan         Plan?    @relation(fields: [planId], references: [id])
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  lastLoginAt  DateTime?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyAccess  UserCompanyAccess[]
  jobs           Job[]
  portfolios     Portfolio[]
  shares         OutputShare[]

  // Legacy relations (kept for migration)
  scans          Scan[]
  reports        Report[]
  companyProfile CompanyProfile?
  newsItems      CompetitorNewsItem[]

  @@map("users")
}

model Plan {
  id           String  @id @default(cuid())
  name         String  @unique // free | pro | operator | portfolio | enterprise
  displayName  String
  description  String?
  priceMonthly Int?    // cents
  priceAnnual  Int?    // cents
  entitlements Json    // PlanEntitlements shape
  stripePriceIdMonthly  String?
  stripePriceIdAnnual   String?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]

  @@map("plans")
}

model Company {
  id          String  @id @default(cuid())
  name        String
  url         String?
  sector      String?
  location    String?
  description String?
  profile     Json?   // detailed ICP/competitor/strategy inputs
  createdById String
  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users         UserCompanyAccess[]
  jobs          Job[]
  outputs       Output[]
  competitors   CompetitorProfile[]
  shares        OutputShare[]
  strategicBets StrategicBet[]

  @@index([createdById])
  @@map("companies")
}

model UserCompanyAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String   @default("editor") // owner | editor | viewer
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_company_access")
}

model Portfolio {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies Company[]

  @@index([createdById])
  @@map("portfolios")
}

model Job {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  workflowType String    // diagnose | decide | position | act | competitor_intel
  status       String    @default("pending") // pending | running | completed | failed
  progress     Int       @default(0)
  outputId     String?   @unique
  output       Output?   @relation(fields: [outputId], references: [id])
  metadata     Json?     // inputs, config
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  events JobEvent[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([workflowType])
  @@map("jobs")
}

model Output {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflowType String   // diagnose | decide | position | act | competitor_intel
  outputType   String   // executive_strategic_brief | strategic_diagnosis | positioning_recommendation etc.
  title        String
  sections     Json     // OutputSections shape (10 mandatory sections)
  version      Int      @default(1)
  confidence   Float?
  sources      String[]
  tags         String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  job           Job?
  itemStatuses  ItemStatus[]
  strategicBets StrategicBet[]

  @@index([companyId])
  @@index([workflowType])
  @@map("outputs")
}

model ItemStatus {
  id        String   @id @default(cuid())
  outputId  String
  output    Output   @relation(fields: [outputId], references: [id], onDelete: Cascade)
  companyId String
  itemType  String   // "assumption" | "risk" | "action"
  itemIndex Int      // position in the array
  status    String   // type-specific status value
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([outputId, itemType, itemIndex])
  @@index([companyId, itemType])
  @@map("item_statuses")
}

model OutputFeedback {
  id            String   @id @default(cuid())
  outputId      String?
  jobId         String?
  companyId     String
  userId        String
  workflowType  String
  overallRating Int      // 1-5 quick star click
  accuracy      Int?     // 1-5 detailed
  depth         Int?
  actionability Int?
  relevance     Int?
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([workflowType])
  @@map("output_feedback")
}

model OutputShare {
  id             String   @id @default(cuid())
  outputId       String?
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sharedById     String
  sharedBy       User     @relation(fields: [sharedById], references: [id])
  recipientEmail String
  workflowType   String
  stageName      String
  createdAt      DateTime @default(now())

  @@index([companyId])
  @@index([sharedById])
  @@map("output_shares")
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([jobId])
  @@map("job_events")
}

model CompetitorProfile {
  id                     String    @id @default(cuid())
  companyId              String
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                   String
  url                    String?
  latestTeardownOutputId String?
  // Scheduling fields — controls automatic refresh
  refreshIntervalDays    Int       @default(30)
  lastRefreshedAt        DateTime?
  jobContext             Json?     // stores the context fields (competitor_url, relationship, etc.) for re-runs
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([lastRefreshedAt])
  @@map("competitor_profiles")
}

// ─── Legacy Models (kept for data migration) ─────────────────

model CompanyProfile {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String?
  url      String?
  location String?
  icp1     String?
  icp2     String?
  icp3     String?
  territories     String[] @default([])
  inflectionPoint String?
  risks           String?
  bigBet          String?
  aiAmbition      String?
  selfWeakness    String?
  competitor1  String?
  competitor2  String?
  competitor3  String?
  competitor4  String?
  competitor5  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_profiles")
}

model Scan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   String
  status String @default("PENDING")

  companyUrl  String
  companyName String?
  userQuestion String?

  icp             String?
  bigBet          String?
  aiAmbition      String?
  selfWeakness    String?
  inflectionPoint String?
  risks           String?

  priorities       String[]
  workflow         Json?
  competitors      String[]
  investmentThesis String?

  jobId       String?   @unique
  startedAt   DateTime?
  completedAt DateTime?
  errorMessage String?
  progress    Int       @default(0)

  mode String @default("PUBLIC_SIGNAL")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploads   Upload[]
  artifacts ResearchArtifact[]
  results   AnalysisResult[]
  reports   Report[]
  events    ScanEvent[]

  @@index([userId, type])
  @@index([status])
  @@map("scans")
}

model Upload {
  id         String @id @default(cuid())
  scanId     String
  scan       Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  fileSize   Int
  storageKey String
  parsedText String?
  createdAt  DateTime @default(now())

  @@index([scanId])
  @@map("uploads")
}

model ResearchArtifact {
  id         String   @id @default(cuid())
  scanId     String
  scan       Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  source     String
  sourceType String
  content    Json
  rawHtml    String?
  fetchedAt  DateTime @default(now())

  @@index([scanId])
  @@map("research_artifacts")
}

model AnalysisResult {
  id               String   @id @default(cuid())
  scanId           String
  scan             Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  module           String
  output           Json
  confidence       Float
  sources          String[]
  durationMs       Int
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime @default(now())

  @@unique([scanId, module])
  @@index([scanId])
  @@map("analysis_results")
}

model Report {
  id          String    @id @default(cuid())
  scanId      String
  scan        Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  htmlContent String
  pdfUrl      String?
  version     Int       @default(1)
  openedAt    DateTime?
  downloadedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scanId])
  @@index([userId])
  @@map("reports")
}

model ScanEvent {
  id        String   @id @default(cuid())
  scanId    String
  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([scanId])
  @@index([event])
  @@map("scan_events")
}

model CompetitorNewsItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  companyUrl  String
  title       String
  url         String
  source      String?
  summary     String?
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())

  @@unique([userId, url])
  @@index([userId, companyName])
  @@index([userId, fetchedAt])
  @@map("competitor_news_items")
}

model IntegrationInterest {
  id          String   @id @default(cuid())
  email       String
  integration String
  createdAt   DateTime @default(now())

  @@map("integration_interests")
}

// Per-item accept/decline feedback for learning & improvement
model ItemFeedback {
  id           String   @id @default(cuid())
  outputId     String
  companyId    String
  userId       String
  itemType     String   // "risk" | "action" | "monitor"
  itemIndex    Int
  itemText     String   // snapshot of the item text for analysis
  workflowType String   // "frame" | "diagnose" | "decide" | "position" | "commit"
  feedback     String   // "accepted" | "declined"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([outputId, itemType, itemIndex, userId])
  @@index([companyId])
  @@index([userId])
  @@index([workflowType])
  @@index([feedback])
  @@index([itemType])
  @@map("item_feedback")
}

// Strategic bets generated by the Bet stage agent
model StrategicBet {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outputId   String
  output     Output   @relation(fields: [outputId], references: [id], onDelete: Cascade)
  betIndex   Int      // position in the generated array (0-7)
  name       String   // "Bet name" — punchy 3-6 word title
  action     String   // single-sentence commitment
  outcome    String   // measurable 12-month result
  hypothesis String   // "We believe X will result in Y because Z"
  betType    String   // "product" | "go-to-market"
  createdAt  DateTime @default(now())

  selections StrategicBetSelection[]

  @@unique([outputId, betIndex])
  @@index([companyId])
  @@map("strategic_bets")
}

// Tracks which strategic bets a user chose to commit to
model StrategicBetSelection {
  id             String       @id @default(cuid())
  companyId      String
  userId         String
  betId          String
  bet            StrategicBet @relation(fields: [betId], references: [id], onDelete: Cascade)
  commitOutputId String?      // links to the Commit stage Output
  createdAt      DateTime     @default(now())

  @@unique([betId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("strategic_bet_selections")
}
